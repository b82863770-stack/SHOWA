<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
  <title>SHOWA</title>
  
  <!-- إعدادات تخص نظام iOS ليصبح التطبيق ملء الشاشة -->
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="SHOWA" />
  <link rel="apple-touch-icon" href="icon.png" />
  <link rel="manifest" href="manifest.json" />

  <style>
    :root {
      --bg-color: #0f172a;
      --card-bg: #1e293b;
      --accent-color: #6366f1;
      --text-main: #f8fafc;
      --text-sub: #94a3b8;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      background-color: var(--bg-color);
      color: var(--text-main);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      padding-bottom: 20px;
    }

    /* شاشة البداية Splash Screen */
    #splash {
      position: fixed;
      inset: 0;
      background: linear-gradient(135deg, #4f46e5, #06b6d4);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      z-index: 9999;
      transition: opacity 0.5s ease, visibility 0.5s;
    }

    #splash.fade-out {
      opacity: 0;
      visibility: hidden;
    }

    .logo-text {
      font-size: 3.5rem;
      font-weight: 900;
      letter-spacing: 6px;
      color: #fff;
      text-shadow: 0 4px 12px rgba(0,0,0,0.3);
    }

    .sub-text {
      color: rgba(255,255,255,0.8);
      font-size: 0.95rem;
      margin-top: 6px;
    }

    /* الهيدر العلوي */
    header {
      padding: 50px 20px 16px 20px;
      background-color: var(--card-bg);
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .brand {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: 2px;
      color: var(--accent-color);
    }

    /* المحتوى */
    main {
      padding: 20px;
      flex: 1;
    }

    .welcome-card {
      background: linear-gradient(135deg, #6366f1, #4f46e5);
      padding: 24px;
      border-radius: 20px;
      margin-bottom: 24px;
      box-shadow: 0 10px 25px rgba(99, 102, 241, 0.3);
    }

    .welcome-card h2 {
      font-size: 1.4rem;
      margin-bottom: 8px;
    }

    .welcome-card p {
      font-size: 0.9rem;
      opacity: 0.9;
    }

    .section-title {
      font-size: 1.1rem;
      margin-bottom: 16px;
      color: var(--text-sub);
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .grid-item {
      background-color: var(--card-bg);
      padding: 20px;
      border-radius: 16px;
      text-align: center;
      border: 1px solid rgba(255,255,255,0.05);
      transition: transform 0.2s;
    }

    .grid-item:active {
      transform: scale(0.96);
    }

    .icon {
      font-size: 2rem;
      margin-bottom: 8px;
      display: block;
    }

    .item-title {
      font-size: 0.9rem;
      font-weight: 600;
    }
  </style>
</head>
<body>

  <!-- شاشة Splash -->
  <div id="splash">
    <div class="logo-text">SHOWA</div>
    <div class="sub-text">Mobile Experience</div>
  </div>

  <!-- الشريط العلوي -->
  <header>
    <div class="brand">SHOWA</div>
  </header>

  <!-- المحتوى الرئيسي -->
  <main>
    <div class="welcome-card">
      <h2>مرحباً بك في SHOWA</h2>
      <p>التطبيق جاهز للعمل على الآيفون بتصميم عصري وأداء سريع.</p>
    </div>

    <div class="section-title">الأقسام الرئيسية</div>

    <div class="grid">
      <div class="grid-item" onclick="alert('قسم الرئيسية')">
        <span class="icon">🎬</span>
        <div class="item-title">الرئيسية</div>
      </div>
      <div class="grid-item" onclick="alert('المفضلة')">
        <span class="icon">⭐</span>
        <div class="item-title">المفضلة</div>
      </div>
      <div class="grid-item" onclick="alert('البحث')">
        <span class="icon">🔍</span>
        <div class="item-title">البحث</div>
      </div>
      <div class="grid-item" onclick="alert('الإعدادات')">
        <span class="icon">⚙️</span>
        <div class="item-title">الإعدادات</div>
      </div>
    </div>
  </main>

  <script>
    window.addEventListener('load', () => {
      setTimeout(() => {
        document.getElementById('splash').classList.add('fade-out');
      }, 1800);
    });

    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('sw.js');
    }
  </script>
</body>
</html>
